---
const itinerary = [
  {
    title: "Osaka, Dotonbori y Shinsaibashi",
    desc: "Cuatro noches para explorar los letreros gigantes y probar el auténtico takoyaki callejero.",
    tag: "Día 1-4",
    image: "/images/dotonbori.webp"
  },
  {
    title: "Barrio de Asakusa",
    desc: "Recorrido para admirar templos antiguos y cruzar la imponente Puerta Kaminarimon.",
    tag: "Día 5",
    image: "/images/templos-asakusa.webp"
  },
  {
    title: "Distrito de Shibuya",
    desc: "Caminata por las icónicas líneas blancas del cruce peatonal más famoso e iluminado del mundo.",
    tag: "Día 6-8",
    image: "/images/shibuya.webp"
  },
  {
    title: "Tren Bala Shinkansen",
    desc: "Traslados incluidos a bordo del tren más rápido y avanzado de Asia.",
    tag: "Logística",
    image: "/images/nozomi.webp"
  }
];
---

<section class="py-24 bg-gray-50 overflow-hidden">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 uppercase tracking-tight">
      TU <span class="text-japan-red">ITINERARIO</span> EN UNA SOLA MIRADA
    </h2>

    <div id="itinerary-slider" class="flex overflow-x-auto pb-12 gap-6 snap-x snap-mandatory no-scrollbar px-4 -mx-4 md:mx-0 md:px-0 scroll-smooth">
      {itinerary.map(item => (
        <div class="shrink-0 w-[85vw] md:w-[calc(50%-12px)] lg:w-[calc(25%-18px)] bg-white rounded-3xl overflow-hidden shadow-xl snap-center border border-gray-100 flex flex-col group hover:border-japan-red transition-colors">
          <div class="h-48 overflow-hidden">
            <img src={item.image} alt={item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          </div>
          <div class="p-8 flex-1 flex flex-col justify-between">
            <div>
              <span class="inline-block px-3 py-1 bg-japan-red/10 text-japan-red text-sm font-bold rounded-full mb-6 uppercase">
                {item.tag}
              </span>
              <h3 class="text-2xl font-bold mb-4 group-hover:text-japan-red transition-colors">{item.title}</h3>
              <p class="text-gray-600 italic">
                "{item.desc}"
              </p>
            </div>
            <div class="mt-8 flex justify-end">
               <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 group-hover:bg-japan-red group-hover:text-white transition-all">
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                 </svg>
               </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    

  </div>
</section>



<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
