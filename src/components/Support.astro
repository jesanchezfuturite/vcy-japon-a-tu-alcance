---
const supportItems = [
  {
    title: "Coordinador a bordo",
    desc: "Un experto de nuestro equipo te acompaña durante todo el viaje para guiarte en el destino y resolver cualquier imprevisto.",
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
  },
  {
    title: "Logística totalmente resuelta",
    desc: "Olvídate de descifrar mapas en japonés; tus boletos de tren bala y traslados aeropuerto-hotel ya están incluidos y coordinados.",
    icon: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
  },
  {
    title: "Acceso garantizado",
    desc: "Nos encargamos de gestionar tu permiso QR obligatorio para que pases migración rápido y sin complicaciones a tu llegada.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  },
  {
    title: "Asistencia en tu idioma",
    desc: "Soporte en español antes y durante el viaje para que solo te preocupes por disfrutar y tomar fotos.",
    icon: "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
  }
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-16 uppercase tracking-tight">
      EL <span class="text-japan-red">RESPALDO</span> QUE NECESITAS AL VIAJAR LEJOS
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {supportItems.map(item => (
        <div class="p-8 rounded-3xl bg-gray-50 border border-gray-100 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 text-center flex flex-col items-center">
          <div class="w-16 h-16 bg-japan-red/10 text-japan-red rounded-2xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4">{item.title}</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            {item.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
